APP_ENV=local
APP_DEBUG=false
APP_TIMEZONE=UTC

# استخدم mysql بشكل افتراضي، ويمكن التبديل إلى pgsql عند الحاجة
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=emergency_center
DB_USERNAME=root
DB_PASSWORD=

# بديل اختياري: DATABASE_URL=mysql://user:pass@host:3306/dbname
# DATABASE_URL=

JWT_SECRET=change-this-secret-before-production
