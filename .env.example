# إعدادات التطبيق الأساسية
APP_ENV=local
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_CORS_ORIGIN=*

# إعدادات قاعدة البيانات المفصلة
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=emergency_centre
DB_USER=postgres
DB_PASSWORD=postgres

# رابط قاعدة البيانات المجمع (يُفضل استخدامه على Render)
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=

# مفتاح التشفير (يجب توليد مفتاح جديد معقد وعدم استخدام هذا النص)
JWT_SECRET=change-this-secret-before-production
